{
  "env": {
    "MSYS2_PATH_TYPE": "inherit"
  },
  "permissions": {
    "allow": [
      "AskUserQuestion",
      "Bash(cargo:*)",
      "Bash(cat:*)",
      "Bash(dir:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(just:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(pnpm:*)",
      "Bash(rg:*)",
      "Bash(tail:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(xargs:*)",
      "Edit",
      "Glob",
      "Grep",
      "LS",
      "mcp__github__get_file_contents",
      "mcp__github__search_code",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__plugin_context7_context7__resolve-library-id",
      "MultiEdit",
      "Read",
      "Skill",
      "WebFetch",
      "WebSearch",
      "Write"
    ],
    "defaultMode": "auto"
  },
  "model": "opus",
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "clamor",
            "args": [
              "--notify",
              "--body",
              "Needs your input to continue",
              "--audio",
              "~/.dotfiles/agent-configs/claude-code/snd/wait_i_read_you.wav",
              "--audio",
              "~/.dotfiles/agent-configs/claude-code/snd/wait_orders_captain.wav",
              "--audio",
              "~/.dotfiles/agent-configs/claude-code/snd/wait_reporting_for_duty.wav",
              "--audio",
              "~/.dotfiles/agent-configs/claude-code/snd/wait_yes_sir.wav",
              "--volume",
              "0.3"
            ]
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "clamor",
            "args": [
              "--audio",
              "~/.dotfiles/agent-configs/claude-code/snd/yes_affirmative.wav",
              "--audio",
              "~/.dotfiles/agent-configs/claude-code/snd/yes_orders_received.wav",
              "--audio",
              "~/.dotfiles/agent-configs/claude-code/snd/yes_right_away_sir.wav",
              "--audio",
              "~/.dotfiles/agent-configs/claude-code/snd/yes_roger_that.wav",
              "--volume",
              "0.3"
            ]
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh $HOME/.dotfiles/agent-configs/claude-code/hooks/brief-reminder.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "clamor",
            "args": [
              "--audio",
              "~/.dotfiles/agent-configs/claude-code/snd/ready_scv_good_to_go_sir.wav",
              "--volume",
              "0.3"
            ]
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "clamor",
            "args": [
              "--when",
              ".background_tasks | length == 0",
              "--notify",
              "--body",
              "Ready for your input",
              "--audio",
              "~/.dotfiles/agent-configs/claude-code/snd/stop_jobs_finished.wav",
              "--audio",
              "~/.dotfiles/agent-configs/claude-code/snd/ready_scv_good_to_go_sir.wav",
              "--volume",
              "0.3"
            ]
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "clamor",
            "args": [
              "--notify",
              "--body",
              "Something went wrong",
              "--audio",
              "~/.dotfiles/agent-configs/claude-code/snd/error_additional_supply_depots_required.wav",
              "--audio",
              "~/.dotfiles/agent-configs/claude-code/snd/error_insufficient_vespene_gas.wav",
              "--audio",
              "~/.dotfiles/agent-configs/claude-code/snd/error_landing_sequence_interrupted.wav",
              "--audio",
              "~/.dotfiles/agent-configs/claude-code/snd/error_not_enough_energy.wav",
              "--audio",
              "~/.dotfiles/agent-configs/claude-code/snd/error_not_enough_minerals.wav",
              "--audio",
              "~/.dotfiles/agent-configs/claude-code/snd/error_unacceptable_landing_zone.wav",
              "--volume",
              "0.3"
            ]
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "ccstat-rs",
    "padding": 0
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "linear@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "sentry@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "example-skills@anthropic-agent-skills": true,
    "code-simplifier@claude-plugins-official": true,
    "document-skills@anthropic-agent-skills": true,
    "squint@claude-configs": true
  },
  "outputStyle": "Brief",
  "showClearContextOnPlanAccept": true,
  "autoUpdatesChannel": "latest",
  "tui": "default",
  "autoCompactEnabled": false,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
